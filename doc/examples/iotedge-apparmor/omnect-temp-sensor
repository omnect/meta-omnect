# AppArmor profile for the SimulatedTemperatureSensor IoT Edge module.
#
# This is functionally Docker's built-in "docker-default" profile (so the
# .NET module runs normally) plus one extra demo rule that denies writes
# under /tmp/forbidden. The profile name below MUST match the name used in
# the deployment's createOptions: HostConfig.SecurityOpt ["apparmor=omnect-temp-sensor"].
#
# Load on the device with:
#   sudo cp omnect-temp-sensor /etc/apparmor.d/omnect-temp-sensor
#   sudo apparmor_parser -r -W /etc/apparmor.d/omnect-temp-sensor
# (requires the device to be booted with AppArmor active:
#  lsm=landlock,lockdown,yama,loadpin,safesetid,bpf,apparmor)

#include <tunables/global>

profile omnect-temp-sensor flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>

  network,
  capability,
  file,
  umount,

  # Host (privileged) and dockerd processes may send signals to container
  # processes (e.g. docker kill).
  signal (receive) peer=unconfined,
  # runc may send a 'kill' signal to the container's init process (docker stop).
  signal (receive) peer=runc,
  # Container processes may send signals amongst themselves.
  signal (send,receive) peer=omnect-temp-sensor,

  deny @{PROC}/* w,   # deny write for all files directly in /proc (not in a subdir)
  # deny write to files not in /proc/<number>/** or /proc/sys/**
  deny @{PROC}/{[^1-9],[^1-9][^0-9],[^1-9s][^0-9y][^0-9s],[^1-9][^0-9][^0-9][^0-9]*}/** w,
  deny @{PROC}/sys/[^k]** w,  # deny /proc/sys except /proc/sys/k* (effectively /proc/sys/kernel)
  deny @{PROC}/sys/kernel/{?,??,[^s][^h][^m]**} w,  # deny everything except shm* in /proc/sys/kernel/
  deny @{PROC}/sysrq-trigger rwklx,
  deny @{PROC}/kcore rwklx,

  deny mount,

  deny /sys/[^f]*/** wklx,
  deny /sys/f[^s]*/** wklx,
  deny /sys/fs/[^c]*/** wklx,
  deny /sys/fs/c[^g]*/** wklx,
  deny /sys/fs/cg[^r]*/** wklx,
  deny /sys/firmware/** rwklx,
  deny /sys/kernel/security/** rwklx,

  # --- omnect demo rule -------------------------------------------------
  # Deny writes to anything under /tmp/forbidden AND log the denial. The module
  # runs fine; the denial is observable (see README verification step). The
  # `audit` qualifier is required: a plain `deny` blocks the write but quietly
  # (no log). With `audit deny` the denial is emitted as an AppArmor audit record
  # (this image has no auditd, so the record reaches the kernel ring buffer / dmesg).
  audit deny /tmp/forbidden** w,
  # ----------------------------------------------------------------------

  # suppress ptrace denials when using 'docker ps' or 'ps' inside a container
  ptrace (trace,read,tracedby,readby) peer=omnect-temp-sensor,
}
