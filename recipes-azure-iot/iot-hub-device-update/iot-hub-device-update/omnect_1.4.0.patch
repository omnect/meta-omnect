+    g_rebootCapture.callCount++;
+    g_rebootCapture.howto = howto;
+    if (g_rebootCapture.returnValue != 0)
+    {
+        errno = g_rebootCapture.errnoValue;
+    }
+    return g_rebootCapture.returnValue;
+}
